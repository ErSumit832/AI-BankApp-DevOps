
pipeline {
    agent any

    environment {
        IMAGE_NAME = "ai_bank_app"
        IMAGE_TAG  = "latest"
    }

    stages{
        stage("code checkout"){
            steps{
                git url:"https://github.com/ErSumit832/AI-BankApp-DevOps.git", branch:"main"
            }
        }
        stage("docker build"){
            steps{
                sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
            }
        }
        stage("push to docker hub"){
            steps{
                withCredentials([usernamePassword(
                    credentialsId: "dockerHubCreds",
                    passwordVariable: "dockerHubPass",
                    usernameVariable: "dockerHubUser",
                )]) {
                    sh "docker login -u ${env.dockerHubUser} -p ${env.dockerHubPass}"
                    sh "docker image tag my-app ${env.dockerHubUser}/ai_bank_app:latest"
                    sh "docker push ${env.dockerHubUser}/ai_bank_app:latest"
                    
                    }
                }
            }
        stage("testing "){
            steps{
                echo "✅ Basic pipeline test passed"
                 
            }
            
        }
        stage("code deploy"){
            steps{
                sh "docker-compose up -d --build ai_bank_app:latest "
            }
        }
        
    }
}
    